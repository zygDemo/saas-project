
// ==================== 基础设施域 (Infrastructure) ====================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ONLINE
  OFFLINE
  ABNORMAL
  DISABLED
}

enum OrgStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum LeadStatus {
  PENDING_ASSIGN
  PENDING_FOLLOW
  FOLLOWING
  CONVERTED
  INVALID
  DORMANT
  PUBLIC_POOL
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  PENDING_RISK_PRE
  RISK_PRE_PASSED
  RISK_PRE_REJECTED
  PENDING_FUNDER_PRE
  FUNDER_PRE_PASSED
  FUNDER_PRE_REJECTED
  PENDING_FIRST_REVIEW
  FIRST_REVIEW_PASSED
  FIRST_REVIEW_REJECTED
  PENDING_SUPPLEMENT
  PENDING_FINAL_REVIEW
  FINAL_REVIEW_PASSED
  FINAL_REVIEW_REJECTED
  PENDING_FUNDER_REVIEW
  FUNDER_REVIEW_PASSED
  FUNDER_REVIEW_REJECTED
  PENDING_SIGN
  SIGNING_PROGRESS
  SIGNED
  PENDING_LOAN_REQUEST
  LOAN_REQUEST_REVIEWING
  LOAN_REQUEST_APPROVED
  LOAN_REQUEST_REJECTED
  PENDING_DISBURSEMENT
  DISBURSED
  CANCELLED
  SETTLED
}

enum ApprovalAction {
  PASS
  REJECT
  SUPPLEMENT
  TRANSFER
  RETURN
  REMARK
}

enum SignStatus {
  PENDING
  SENT
  SIGNED
  VIDEO_INTERVIEW_DONE
  EXPIRED
  CANCELLED
}

enum DisbursementStatus {
  PENDING_APPLICATION
  PENDING_APPROVAL
  GPS_INSTALLED
  MORTGAGE_DONE
  DISBURSED
  FAILED
}

enum RepaymentStatus {
  NOT_DUE
  PENDING
  PARTIAL
  PAID
  OVERDUE
  SETTLED
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

model Tenant {
  id               Int               @id @default(autoincrement())
  name             String
  code             String            @unique
  status           String            @default("active")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  users            User[]
  roles            Role[]
  menus            Menu[]
  permissions      Permission[]
  dictTypes        DictType[]
  dictData         DictData[]
  fileAssets       FileAsset[]
  organizations    Organization[]
  departments      Department[]
  products         Product[]
  funders          Funder[]
  flowConfigs      FlowConfig[]
  leads            Lead[]
  customers        Customer[]
  applications     Application[]
  approvalRecords  ApprovalRecord[]
  signRecords      SignRecord[]
  disbursements    Disbursement[]
  repaymentPlans   RepaymentPlan[]
  repaymentRecords RepaymentRecord[]

  // 读书模块
  bookCategories    BookCategory[]
  books             Book[]
  bookChapters      BookChapter[]
  userBookshelves   UserBookshelf[]
  readingProgresses ReadingProgress[]
  bookReviews       BookReview[]
  readingNotes ReadingNote[]
  systemParams      SystemParam[]
  announcements     Announcement[]
  messageTemplates MessageTemplate[]
  collectionRecords CollectionRecord[]
  earlyRepayments   EarlyRepayment[]
  workOrders        WorkOrder[]

  // 文章模块
  articles          Article[]
  articleTypes      ArticleType[]

  // 点餐模块
  foodCategories  FoodCategory[]
  foodDishes      FoodDish[]
  foodOrders      FoodOrder[]
  foodCarts       FoodCart[]

  // 移动端模块配置
  mobileModules       Json?    // ["carloan","food","credit"] 已启用的移动端模块
  defaultMobileModule String?  // 单模块模式下的默认模块 key
}

model User {
  id           Int         @id @default(autoincrement())
  tenantId     Int
  deptId       Int?
  userName     String
  passwordHash String
  nickName     String
  gender       String      @default("未知")
  phone        String?
  email        String?
  avatar       String?
  status       UserStatus  @default(ONLINE)
  createdBy    String      @default("system")
  updatedBy    String      @default("system")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  foodOrders   FoodOrder[]
  foodCarts    FoodCart[]
  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  dept         Department? @relation(fields: [deptId], references: [id])
  roles        UserRole[]

  // 移动端模块配置（用户级，最高优先级）
  mobileModules       Json?    // ["carloan"] 用户可访问的移动端模块
  mobileMultiModule   Boolean  @default(false) // 是否支持多业务模块

  // 业务关联
  leads        Lead[]
  applications Application[]    @relation("ApplicationCreator")
  approvals    ApprovalRecord[]

  // 读书模块关联
  chapterPurchases ChapterPurchase[]
  reviewLikes      ReviewLike[]
  articleLikes     ArticleLike[]

  @@unique([tenantId, userName])
  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([deptId])
  deletedAt    DateTime?   // 软删除时间戳
}

model Role {
  id          Int              @id @default(autoincrement())
  tenantId    Int
  name        String
  code        String
  description String           @default("")
  enabled     Boolean          @default(true)
  dataScope   String           @default("ALL") // 数据范围：ALL、DEPT、SELF、CUSTOM
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  users       UserRole[]
  menus       RoleMenu[]
  permissions RolePermission[]

  // 移动端模块配置（角色级，覆盖租户配置）
  mobileModules       Json?    // ["carloan","food"] 角色可访问的移动端模块
  mobileMultiModule   Boolean  @default(false) // 是否支持多业务模块

  departments  RoleDepartment[]

  @@unique([tenantId, code])
  @@index([tenantId])
  deletedAt    DateTime?   // 软删除时间戳
}

model UserRole {
  userId Int
  roleId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Menu {
  id          Int          @id @default(autoincrement())
  tenantId    Int
  parentId    Int?
  path        String
  name        String
  component   String       @default("")
  title       String
  icon        String?
  sort        Int          @default(0)
  keepAlive   Boolean      @default(false)
  hidden      Boolean      @default(false)
  hiddenTab   Boolean      @default(false)
  link        String?
  iframe      Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  parent      Menu?        @relation("MenuTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    Menu[]       @relation("MenuTree")
  roles       RoleMenu[]
  permissions Permission[]

  @@unique([tenantId, name])
  @@index([tenantId])
  deletedAt    DateTime?   // 软删除时间戳
}

model RoleMenu {
  roleId Int
  menuId Int
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  menu   Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)

  @@id([roleId, menuId])
  deletedAt    DateTime?   // 软删除时间戳
}

model RoleDepartment {
  roleId       Int
  departmentId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([roleId, departmentId])
}

model Permission {
  id        Int              @id @default(autoincrement())
  tenantId  Int
  menuId    Int
  title     String
  authMark  String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  tenant    Tenant           @relation(fields: [tenantId], references: [id])
  menu      Menu             @relation(fields: [menuId], references: [id], onDelete: Cascade)
  roles     RolePermission[]

  @@unique([tenantId, menuId, authMark])
  @@index([tenantId])
  deletedAt    DateTime?   // 软删除时间戳
}

model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  deletedAt    DateTime?   // 软删除时间戳
}

model DictType {
  id        Int        @id @default(autoincrement())
  tenantId  Int
  name      String
  code      String
  status    String     @default("ACTIVE")
  remark    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items     DictData[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([status])
  deletedAt    DateTime?   // 软删除时间戳
}

model DictData {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  typeId    Int
  label     String
  value     String
  sort      Int      @default(0)
  status    String   @default("ACTIVE")
  remark    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type      DictType @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, typeId, value])
  @@index([tenantId])
  @@index([typeId])
  @@index([status])
  deletedAt    DateTime?   // 软删除时间戳
}

model FileAsset {
  id           Int      @id @default(autoincrement())
  tenantId     Int
  orgId        Int?
  businessType String?
  businessId   Int?
  categoryCode String
  categoryName String
  fileName     String
  fileUrl      String
  objectKey    String?
  mimeType     String?
  fileExt      String?
  fileSize     Int?
  storageType  String   @default("LOCAL")
  status       String   @default("ACTIVE")
  uploadedBy   Int?
  remark       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([orgId])
  @@index([businessType, businessId])
  @@index([categoryCode])
  @@index([status])
  @@index([uploadedBy])
  deletedAt    DateTime?   // 软删除时间戳
}

model OperationLog {
  id           Int      @id @default(autoincrement())
  tenantId     Int?
  orgId        Int?
  userId       Int?
  userName     String?
  module       String // 模块
  action       String // 操作类型
  description  String? // 操作描述
  requestData  Json? // 请求数据
  responseData Json? // 响应数据
  ip           String?
  statusCode   Int      @default(200) // HTTP状态码
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([tenantId])
  @@index([orgId])
  @@index([userId])
  @@index([module])
  @@index([createdAt])
  @@index([statusCode])
}

model SystemParam {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  group     String?  @db.VarChar(50)   // 参数分组：basic, security, sms 等
  name      String   @db.VarChar(100)  // 参数名称
  key       String   @db.VarChar(100)  // 参数键（英文唯一标识）
  value     String?  @db.Text          // 参数值
  type      String   @default("STRING") @db.VarChar(20) // STRING, NUMBER, BOOLEAN, JSON
  status    String   @default("ACTIVE") @db.VarChar(20)
  remark    String?  @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([group])
  @@index([status])
}


// ==================== 机构配置域 (Organization & Config) ====================

model Organization {
  id           Int       @id @default(autoincrement())
  tenantId     Int
  name         String
  code         String    @unique
  creditCode   String?   @unique // 统一社会信用代码
  contactName  String?
  contactPhone String?
  address      String?
  status       OrgStatus @default(ACTIVE)
  packageType  String? // 套餐类型
  expireAt     DateTime? // 到期时间
  apiEnabled   Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  departments  Department[]
  products     Product[]
  funders      Funder[]
  flowConfigs  FlowConfig[]
  leads        Lead[]
  customers    Customer[]
  applications Application[]

  @@index([tenantId])
  @@index([status])
  deletedAt    DateTime?   // 软删除时间戳
}

model Department {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  orgId     Int
  parentId  Int?
  name      String
  managerId Int? // 部门负责人用户 ID
  sort      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent   Department?  @relation("DeptTree", fields: [parentId], references: [id], onDelete: Cascade)
  children Department[] @relation("DeptTree")
  users    User[]
  roles    RoleDepartment[]

  @@unique([orgId, name])
  @@index([tenantId])
  @@index([orgId])
}

model Product {
  id                    Int      @id @default(autoincrement())
  tenantId              Int
  orgId                 Int
  name                  String
  productType           String // 产品类型：抵押贷、信用贷、融资租赁等
  minRate               Decimal  @db.Decimal(5, 4) // 最低年利率
  maxRate               Decimal  @db.Decimal(5, 4) // 最高年利率
  minAmount             Decimal  @db.Decimal(15, 2)
  maxAmount             Decimal  @db.Decimal(15, 2)
  minTerm               Int // 最短期限（月）
  maxTerm               Int // 最长期限（月）
  repaymentMethod       String // 等额本息、等额本金、先息后本
  minAge                Int?
  maxAge                Int?
  maxCarAge             Int? // 最大车龄
  maxMileage            Int? // 最大里程
  ltvLimit              Decimal? @db.Decimal(5, 4) // 最高贷款价值比
  minDownPayment        Decimal? @db.Decimal(5, 4) // 最低首付比例
  regions               String? // 适用区域，支持 JSON 或逗号分隔
  applicableFunders     Json? // 适用资方 ID 列表或规则清单
  accessConditions      Json? // 准入条件配置
  valuationDiscountRate Decimal? @db.Decimal(5, 4) // 车辆估值折扣率
  status                String   @default("DRAFT") // 状态：DRAFT、ACTIVE、INACTIVE、ARCHIVED
  fileChecklist         Json? // 所需文件清单
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([tenantId])
  @@index([orgId])
  @@index([status])
  deletedAt    DateTime?   // 软删除时间戳
}

model Funder {
  id              Int      @id @default(autoincrement())
  tenantId        Int
  orgId           Int
  name            String
  code            String
  funderType      String // 资方类型：BANK、CONSUMER_FINANCE、LEASING、MICRO_LOAN
  contactName     String?
  contactPhone    String?
  integrationMode String   @default("MANUAL") // 对接方式：API、FILE、MANUAL
  creditLimit     Decimal? @db.Decimal(15, 2)
  apiConfig       Json? // 对接配置
  approvalRules   Json? // 审批/准入规则
  priority        Int      @default(0)
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  org          Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  applications Application[]

  @@unique([orgId, code])
  @@index([tenantId])
  @@index([orgId])
  deletedAt    DateTime?   // 软删除时间戳
}

model FlowConfig {
  id               Int      @id @default(autoincrement())
  tenantId         Int
  orgId            Int
  name             String
  businessType     String // 业务类型：LOAN、LEASE、PAWN 等
  nodeCode         String // 流程节点编码：LEAD、APPLICATION、APPROVAL、SIGNING、DISBURSEMENT
  nodeName         String
  approveLevel     Int      @default(1)
  amountLimit      Decimal? @db.Decimal(15, 2)
  timeoutHours     Int?
  requireMaterials Boolean  @default(false)
  requireApproval  Boolean  @default(true)
  autoPass         Boolean  @default(false)
  ruleConfig       Json?
  status           String   @default("ACTIVE")
  remark           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, businessType, nodeCode])
  @@index([tenantId])
  @@index([orgId])
  @@index([businessType])
  @@index([nodeCode])
  @@index([status])
  deletedAt    DateTime?   // 软删除时间戳
}

model PackagePlan {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)   // 套餐名称
  code        String   @unique @db.VarChar(50) // 套餐编码
  description String?  @db.VarChar(500)   // 套餐描述
  price       Decimal  @db.Decimal(10, 2) // 月费
  maxUsers    Int      @default(0)        // 最大用户数，0=不限
  maxOrgs     Int      @default(0)        // 最大机构数，0=不限
  features    Json?                        // 功能特性列表
  status      String   @default("ACTIVE") @db.VarChar(20) // ACTIVE, INACTIVE
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([status])
}

model ProductTemplate {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(100)   // 模板名称
  productType     String   @db.VarChar(50)    // 产品类型：抵押贷、信用贷、融资租赁
  description     String?  @db.VarChar(500)
  minRate         Decimal? @db.Decimal(5, 4)
  maxRate         Decimal? @db.Decimal(5, 4)
  minAmount       Decimal? @db.Decimal(15, 2)
  maxAmount       Decimal? @db.Decimal(15, 2)
  minTerm         Int?
  maxTerm         Int?
  repaymentMethod String?  @db.VarChar(50)
  accessConditions Json?                       // 准入条件模板
  fileChecklist   Json?                       // 所需文件清单模板
  status          String   @default("ACTIVE") @db.VarChar(20)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@index([status])
  @@index([productType])
}

model ThirdPartyService {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)   // 服务名称
  code        String   @unique @db.VarChar(50)  // 服务编码
  serviceType String   @db.VarChar(50)    // 类型：SMS, OCR, GPS, CREDIT, PAYMENT
  provider    String   @db.VarChar(100)   // 服务商
  apiUrl      String?  @db.VarChar(500)   // API地址
  config      Json?                        // 配置信息（加密存储）
  status      String   @default("ACTIVE") @db.VarChar(20) // ACTIVE, INACTIVE, ERROR
  lastTestAt  DateTime?                    // 最后测试时间
  lastTestOk  Boolean?                     // 最后测试结果
  remark      String?  @db.VarChar(500)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([status])
  @@index([serviceType])
}


// ==================== 客户管理域 (Customer Management) ====================

model Customer {
  id               Int       @id @default(autoincrement())
  tenantId         Int
  orgId            Int
  name             String
  phone            String
  idCard           String? // 身份证号
  gender           Gender    @default(UNKNOWN)
  birthDate        DateTime?
  nation           String?
  householdAddress String?
  issuingAuthority String?
  idCardValidFrom  String?
  idCardValidTo    String?
  idCardFront      String?
  idCardBack       String?
  maritalStatus    String?
  education        String?
  degree           String?     // 学位
  occupation       String?
  companyName      String?     // 单位名称
  monthlyIncome    Decimal?    @db.Decimal(15, 2)
  dwellingCondition String?    // 居住状况
  liveProvince     String?     // 居住省
  liveCity         String?     // 居住市
  liveDistrict     String?     // 居住区
  liveDetailedAddress String?  // 居住详细地址
  childrenNum      Int?        // 供养子女数
  workingProvince  String?     // 单位省
  workingCity      String?     // 单位市
  workingDistrict  String?     // 单位区
  workingDetailedAddress String? // 单位详细地址
  workingTelephone String?     // 公司电话
  address          String?
  emergencyName    String?
  emergencyPhone   String?
  status           String    @default("ACTIVE")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  org          Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  contacts     CustomerContact[]
  vehicles     Vehicle[]
  bankCards    BankCard[]
  applications Application[]

  @@unique([orgId, phone])
  @@index([tenantId])
  @@index([tenantId, phone])
  @@index([orgId])
  @@index([idCard])
  deletedAt    DateTime?   // 软删除时间戳
}

model CustomerContact {
  id          Int      @id @default(autoincrement())
  customerId  Int
  name        String
  relation    String // 配偶、父母、同事等
  phone       String
  address     String?
  isEmergency Boolean  @default(false)
  createdAt   DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  deletedAt    DateTime?   // 软删除时间戳
}

model Vehicle {
  id                     Int       @id @default(autoincrement())
  customerId             Int
  vin                    String? // 车架号
  plateNumber            String? // 车牌号
  brand                  String?
  model                  String?
  ownerName              String?
  address                String?
  usageNature            String?
  sealInfo               String?
  engineNumber           String?
  registerDate           DateTime?
  vehicleImgUrl          String?
  color                  String?
  year                   Int?
  mileage                Int?
  purchasePrice          Decimal?  @db.Decimal(15, 2)
  estimateValue          Decimal?  @db.Decimal(15, 2) // 评估价/估值
  isMortgaged            Boolean   @default(false)
  mortgageInfo           String?
  fuelType               Int?      // 燃油类型：1-油车 2-纯电 3-油电混合
  isFault                Int?      // 是否故障：1-是 2-否
  purchaseType           Int?      // 购买方式：1-全款 2-按揭
  purchaseDate           DateTime? // 购买日期
  loanAmount             Decimal?  @db.Decimal(15, 2) // 贷款金额（分）
  loanTerm               Int?      // 贷款期限（年）
  monthlyPayment         Decimal?  @db.Decimal(15, 2) // 月还款金额（分）
  isInsurance            Int?      // 是否投保：1-是 2-否
  insuranceExpirationDate DateTime? // 保险到期日
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([vin])
}

model BankCard {
  id         Int      @id @default(autoincrement())
  customerId Int
  bankName   String
  cardNo     String // 卡号（加密存储）
  cardType   String // 借记卡/信用卡
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model Lead {
  id           Int        @id @default(autoincrement())
  tenantId     Int
  orgId        Int
  source       String // 来源：SELF、IMPORT、EXTERNAL、SCAN、REFERRAL
  name         String
  phone        String
  idCard       String? // 身份证号（脱敏存储）
  carBrand     String?
  carModel     String?
  province     String?    // 省
  city         String?    // 市
  loanAmount   Decimal?   @db.Decimal(15, 2)
  remark       String?
  status       LeadStatus @default(PENDING_ASSIGN)
  assigneeId   Int? // 分配给业务员
  nextFollowAt DateTime? // 下次跟进时间
  createdBy    Int? // 创建人
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  org       Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assignee  User?          @relation(fields: [assigneeId], references: [id])
  followUps LeadFollowUp[]

  @@index([tenantId])
  @@index([orgId])
  @@index([phone])
  @@index([tenantId, phone])
  @@index([status])
  @@index([assigneeId])
  deletedAt    DateTime?   // 软删除时间戳
}

model LeadFollowUp {
  id           Int       @id @default(autoincrement())
  leadId       Int
  followType   String // 跟进方式：PHONE、WECHAT、VISIT、OTHER
  content      String
  nextFollowAt DateTime?
  createdBy    Int?
  createdAt    DateTime  @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}


// ==================== 车贷业务域 (Car Loan Business) ====================

model Application {
  id                 Int               @id @default(autoincrement())
  tenantId           Int
  orgId              Int
  customerId         Int
  productId          Int?
  funderId           Int?
  applicationNo      String            @unique // 订单号/申请编号
  amount             Decimal           @db.Decimal(15, 2)
  term               Int // 期限（月）
  rate               Decimal           @db.Decimal(5, 4) // 年利率
  repaymentMethod    String
  purpose            String? // 贷款用途
  status             ApplicationStatus @default(DRAFT)
  businessType       String            @default("CAR_LOAN")
  currentNode        Int               @default(1100)
  currentStatus      Int               @default(10)
  creatorId          Int // 创建人（业务员）
  sourceLeadId       Int? // 来源线索
  supplementReason   String? // 补件原因
  supplementDeadline DateTime? // 补件截止时间
  isSupplementCustomer Int? @default(0) // 客户资料补件状态: 0-未知 1-已补充 2-待补充
  isSupplementVehicle  Int? @default(0) // 车辆资料补件状态
  isSupplementOrder    Int? @default(0) // 订单信息补件状态
  isSupplementFile     Int? @default(0) // 文件信息补件状态
  approvedAmount     Decimal?          @db.Decimal(15, 2) // 审批通过金额
  approvedTerm       Int? // 审批通过期限
  approvedRate       Decimal?          @db.Decimal(5, 4) // 审批通过利率
  remark             String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  org          Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customer     Customer          @relation(fields: [customerId], references: [id])
  product      Product?          @relation(fields: [productId], references: [id])
  funder       Funder?           @relation(fields: [funderId], references: [id])
  creator      User              @relation("ApplicationCreator", fields: [creatorId], references: [id])
  files        ApplicationFile[]
  approvals    ApprovalRecord[]
  signRecord   SignRecord?
  disbursement Disbursement?
  repayments         RepaymentPlan[]
  collectionRecords CollectionRecord[]
  earlyRepayments   EarlyRepayment[]

  @@index([tenantId])
  @@index([orgId])
  @@index([customerId])
  @@index([status])
  @@index([businessType])
  @@index([currentNode])
  @@index([currentStatus])
  @@index([creatorId])
  @@index([applicationNo])
  @@index([tenantId, applicationNo])
  deletedAt    DateTime?   // 软删除时间戳
}

model ApplicationFile {
  id            Int      @id @default(autoincrement())
  applicationId Int
  fileType      String // 文件类型：身份证人像面、身份证国徽面、行驶证、银行卡等
  fileUrl       String
  fileName      String?
  ocrResult     Json? // OCR 识别结果
  isValid       Boolean  @default(true)
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([fileType])
  deletedAt    DateTime?   // 软删除时间戳
}

model ApprovalRecord {
  id            Int            @id @default(autoincrement())
  tenantId      Int
  applicationId Int
  approverId    Int
  stage         String // 审批阶段：FIRST_REVIEW、FINAL_REVIEW、FUNDER_REVIEW 等
  action        ApprovalAction
  opinion       String? // 审批意见
  amount        Decimal?       @db.Decimal(15, 2) // 核定金额
  term          Int? // 核定期限
  rate          Decimal?       @db.Decimal(5, 4) // 核定利率
  createdAt     DateTime       @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  approver    User        @relation(fields: [approverId], references: [id])

  @@index([tenantId])
  @@index([applicationId])
  @@index([approverId])
  @@index([stage])
  deletedAt    DateTime?
}

model SignRecord {
  id              Int        @id @default(autoincrement())
  tenantId        Int
  applicationId   Int        @unique
  status          SignStatus @default(PENDING)
  contractUrl     String? // 合同文件 URL
  signedAt        DateTime?
  videoUrl        String? // 面签视频/录屏
  expiredAt       DateTime? // 签约过期时间
  cancelledReason String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  deletedAt    DateTime?   // 软删除时间戳
}

model Disbursement {
  id              Int                @id @default(autoincrement())
  tenantId        Int
  applicationId   Int                @unique
  status          DisbursementStatus @default(PENDING_APPLICATION)
  gpsDeviceNo     String? // GPS设备号
  gpsInstallImg   String? // GPS安装照片
  gpsInstallAt    DateTime?
  mortgageStatus  String? // 抵押状态
  mortgageImg     String? // 抵押回执
  mortgageAt      DateTime?
  disburseAmount  Decimal?           @db.Decimal(15, 2) // 实际放款金额
  disburseAccount String? // 放款账户
  disburseAt      DateTime?
  transactionNo   String? // 放款流水号
  voucherUrl      String? // 放款凭证文件
  remark          String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  deletedAt    DateTime?   // 软删除时间戳
}

model RepaymentPlan {
  id            Int             @id @default(autoincrement())
  tenantId      Int
  applicationId Int
  period        Int // 期数
  dueDate       DateTime // 应还日期
  principal     Decimal         @db.Decimal(15, 2) // 应还本金
  interest      Decimal         @db.Decimal(15, 2) // 应还利息
  totalAmount   Decimal         @db.Decimal(15, 2) // 应还总额
  paidPrincipal Decimal         @default(0) @db.Decimal(15, 2)
  paidInterest  Decimal         @default(0) @db.Decimal(15, 2)
  paidTotal     Decimal         @default(0) @db.Decimal(15, 2)
  status        RepaymentStatus @default(NOT_DUE)
  overdueDays   Int             @default(0)
  penaltyAmount Decimal         @default(0) @db.Decimal(15, 2) // 违约金
  paidAt        DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  records     RepaymentRecord[]

  @@unique([applicationId, period])
  @@index([tenantId])
  @@index([applicationId])
  @@index([status])
  @@index([dueDate])
  deletedAt    DateTime?   // 软删除时间戳
}

model RepaymentRecord {
  id            Int      @id @default(autoincrement())
  tenantId      Int
  planId        Int
  amount        Decimal  @db.Decimal(15, 2) // 本次还款金额
  principal     Decimal  @db.Decimal(15, 2)
  interest      Decimal  @db.Decimal(15, 2)
  penalty       Decimal  @default(0) @db.Decimal(15, 2)
  paymentMethod String // 支付方式
  transactionNo String? // 还款交易流水号
  voucherUrl    String? // 还款凭证文件
  remark        String?
  createdBy     Int? // 登记人
  createdAt     DateTime @default(now())

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   RepaymentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([planId])
}

model CollectionRecord {
  id            Int      @id @default(autoincrement())
  tenantId      Int
  applicationId Int
  collectorId   Int?
  collectType   String   @default("PHONE")
  content       String
  result        String?
  nextAction    String?
  nextDate      DateTime?
  createdAt     DateTime @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([applicationId])
  @@index([createdAt])
}

model EarlyRepayment {
  id              Int      @id @default(autoincrement())
  tenantId        Int
  applicationId   Int
  repayType       String   @default("FULL")
  amount          Decimal  @db.Decimal(15, 2)
  principal       Decimal  @db.Decimal(15, 2)
  interest        Decimal  @db.Decimal(15, 2)
  penalty         Decimal  @default(0) @db.Decimal(15, 2)
  reason          String?
  repayStatus     String   @default("PENDING")
  approvedBy      Int?
  approvedAt      DateTime?
  completedAt     DateTime?
  remark          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([applicationId])
  @@index([repayStatus])
}


// ==================== 运营管理域 (Operations) ====================

model MessageTemplate {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  name      String   @db.VarChar(100)  // 模板名称
  code      String   @db.VarChar(80)   // 模板编码
  channel   String   @default("SMS") @db.VarChar(30) // SMS, APP, WECHAT, EMAIL, SYSTEM
  scene     String   @default("GENERAL") @db.VarChar(50) // 业务场景
  title     String?  @db.VarChar(200)  // 标题/主题
  content   String   @db.Text          // 模板内容
  variables Json?                       // 变量说明 [{key,label,example}

  status    String   @default("ACTIVE") @db.VarChar(20) // ACTIVE, INACTIVE, DRAFT
  remark    String?  @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([channel])
  @@index([scene])
  @@index([status])
}

model Announcement {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  title     String   @db.VarChar(200)  // 公告标题
  content   String?  @db.Text          // 公告内容（富文本）
  type      String   @default("NOTICE") @db.VarChar(20) // NOTICE, ANNOUNCEMENT, ALERT
  level     String   @default("NORMAL") @db.VarChar(20) // NORMAL, IMPORTANT, URGENT
  status    String   @default("DRAFT") @db.VarChar(20)  // DRAFT, PUBLISHED, EXPIRED
  publishAt DateTime?                  // 发布时间
  expireAt  DateTime?                  // 过期时间
  target    String?  @db.VarChar(100)  // 发布范围
  topFlag   Boolean  @default(false)   // 是否置顶
  viewCount Int      @default(0)       // 查看次数
  remark    String?  @db.VarChar(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([type])
  @@index([publishAt])
}

model WorkOrder {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  title       String   @db.VarChar(200)   // 工单标题
  content     String?  @db.Text           // 工单内容
  orderType   String   @default("FEEDBACK") @db.VarChar(30) // FEEDBACK, BUG, SUGGESTION, SUPPORT
  priority    String   @default("NORMAL") @db.VarChar(20)   // LOW, NORMAL, HIGH, URGENT
  status      String   @default("OPEN") @db.VarChar(20)     // OPEN, PROCESSING, RESOLVED, CLOSED
  creatorId   Int?                        // 创建人
  assigneeId  Int?                        // 处理人
  resolvedAt  DateTime?
  closedAt    DateTime?
  remark      String?  @db.VarChar(500)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([orderType])
  @@index([priority])
  @@index([createdAt])
}


// ==================== 读书管理域 (Reading) ====================

model BookCategory {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  name      String // 分类名称
  parentId  Int? // 父分类ID
  sort      Int      @default(0) // 排序
  status    Int      @default(1) // 状态 1:启用 0:禁用
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  books  Book[]

  @@index([tenantId])
  @@index([parentId])
  deletedAt    DateTime?   // 软删除时间戳
}

model Book {
  id            Int       @id @default(autoincrement())
  tenantId      Int
  title         String // 书名
  author        String // 作者
  cover         String? // 封面URL
  desc          String? // 简介
  categoryId    Int? // 分类ID
  isbn          String? // ISBN
  publisher     String? // 出版社
  publishDate   DateTime? // 出版日期
  wordCount     Int       @default(0) // 字数
  chapterCount  Int       @default(0) // 章节数
  price         Decimal   @default(0) @db.Decimal(10, 2) // 价格
  isFree        Boolean   @default(true) // 是否免费
  isVip         Boolean   @default(false) // 是否VIP
  isSerial      Boolean   @default(true) // 是否连载
  isFinished    Boolean   @default(false) // 是否完结
  isHot         Boolean   @default(false) // 是否热门
  isRecommend   Boolean   @default(false) // 是否推荐
  rating        Decimal   @default(0) @db.Decimal(3, 1) // 评分
  ratingCount   Int       @default(0) // 评分人数
  readCount     Int       @default(0) // 阅读人数
  downloadCount Int       @default(0) // 下载人数
  status        Int       @default(1) // 状态 1:上架 0:下架
  sort          Int       @default(0) // 排序
  tags          String? // 标签，逗号分隔
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category    BookCategory?     @relation(fields: [categoryId], references: [id])
  chapters    BookChapter[]
  bookshelves UserBookshelf[]
  progress    ReadingProgress[]
  reviews     BookReview[]
    readingNotes ReadingNote[]

  @@index([tenantId])
  @@index([categoryId])
  @@index([status])
  @@index([isHot])
  @@index([isRecommend])
  deletedAt    DateTime?
}

model BookChapter {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  bookId    Int
  title     String // 章节标题
  content   String?  @db.Text // 章节内容
  wordCount Int      @default(0) // 字数
  sort      Int      @default(0) // 排序
  isVip     Boolean  @default(false) // 是否VIP章节
  price     Decimal  @default(0) @db.Decimal(10, 2) // 章节价格
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  book             Book             @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapterPurchases ChapterPurchase[]

  @@unique([bookId, sort])
  @@index([tenantId])
  readingNotes ReadingNote[]
  @@index([bookId])
  deletedAt    DateTime?
}

model UserBookshelf {
  id         Int       @id @default(autoincrement())
  tenantId   Int
  userId     Int
  bookId     Int
  lastReadAt DateTime? // 最后阅读时间
  createdAt  DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([tenantId])
  @@index([userId])
  deletedAt    DateTime?   // 软删除时间戳
}

model ReadingProgress {
  id         Int      @id @default(autoincrement())
  tenantId   Int
  userId     Int
  bookId     Int
  chapterId  Int
  page       Int      @default(0) // 页码
  progress   Decimal  @default(0) @db.Decimal(5, 2) // 进度百分比
  readTime   Int      @default(0) // 阅读时长（秒）
  lastReadAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([tenantId])
  @@index([userId])
  @@index([bookId])
}

model BookReview {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  userId    Int
  bookId    Int
  rating    Int // 评分 1-5
  content   String?  @db.Text // 评价内容
  likes     Int      @default(0) // 点赞数
  status    Int      @default(1) // 状态 1:正常 0:隐藏
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  book        Book        @relation(fields: [bookId], references: [id], onDelete: Cascade)
  reviewLikes ReviewLike[]

  @@unique([userId, bookId])
  @@index([tenantId])
  @@index([userId])
  @@index([bookId])
}

model ReadingNote {
  id         Int      @id @default(autoincrement())
  tenantId   Int
  userId     Int
  bookId     Int
  chapterId  Int
  highlight  String?  @db.Text // 高亮文本
  note       String?  @db.Text // 笔记内容
  color      String   @default("#FFEB3B") // 高亮颜色
  startPos   Int      @default(0) // 高亮起始位置
  endPos     Int      @default(0) // 高亮结束位置
  status     Int      @default(1) // 状态 1:正常 0:隐藏
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  book      Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter   BookChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  @@index([tenantId])
  @@index([userId])
  @@index([bookId])
  @@index([chapterId])
  deletedAt  DateTime?
}
// ==================== 文章管理 ====================
model Article {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  title       String
  content     String?  @db.Text
  summary     String?  @db.VarChar(500)
  coverImg    String?
  typeId      Int?
  typeName    String?
  status      String   @default("DRAFT") // DRAFT, PUBLISHED, ARCHIVED
  viewCount   Int      @default(0)
  likeCount   Int      @default(0)
  isTop       Boolean  @default(false)
  publishAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  articleLikes ArticleLike[]

  @@index([tenantId])
  @@index([status])
  @@index([typeId])
}

model ArticleType {
  id        Int      @id @default(autoincrement())
  tenantId  Int
  name      String
  sort      Int      @default(0)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
}


model ChapterPurchase {
  id        Int      @id @default(autoincrement())
  chapterId Int
  userId    Int
  createdAt DateTime @default(now())

  chapter BookChapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chapterId, userId])
  @@index([chapterId])
  @@index([userId])
}

model ReviewLike {
  id        Int      @id @default(autoincrement())
  reviewId  Int
  userId    Int
  createdAt DateTime @default(now())

  review BookReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@index([reviewId])
  @@index([userId])
}

model ArticleLike {
  id        Int      @id @default(autoincrement())
  articleId Int
  userId    Int
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([articleId, userId])
  @@index([articleId])
  @@index([userId])
}

// ==================== 点餐模块 ====================

model FoodCategory {
  id        Int         @id @default(autoincrement())
  name      String      @db.VarChar(50)
  icon      String?     @db.VarChar(100)
  sortOrder Int         @default(0)
  isActive  Boolean     @default(true)
  tenantId  Int
  tenant    Tenant      @relation(fields: [tenantId], references: [id])
  dishes    FoodDish[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([tenantId])
}

model FoodDish {
  id            Int             @id @default(autoincrement())
  name          String          @db.VarChar(100)
  description   String?         @db.VarChar(500)
  price         Decimal         @db.Decimal(10, 2)
  originalPrice Decimal?        @db.Decimal(10, 2)
  imageUrl      String?         @db.VarChar(500)
  categoryId    Int
  category      FoodCategory    @relation(fields: [categoryId], references: [id])
  isActive      Boolean         @default(true)
  sortOrder     Int             @default(0)
  salesCount    Int             @default(0)
  tenantId      Int
  tenant        Tenant          @relation(fields: [tenantId], references: [id])
  orderItems    FoodOrderItem[]
  cartItems     FoodCart[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([tenantId])
  @@index([categoryId])
}

model FoodOrder {
  id         Int             @id @default(autoincrement())
  orderNo    String          @unique @db.VarChar(32)
  status     Int             @default(1) // 1=待接单 2=制作中 3=已完成 4=已取消
  totalPrice Decimal         @db.Decimal(10, 2)
  remark     String?         @db.VarChar(500)
  userId     Int
  user       User            @relation(fields: [userId], references: [id])
  tenantId   Int
  tenant     Tenant          @relation(fields: [tenantId], references: [id])
  items      FoodOrderItem[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@index([tenantId])
  @@index([userId])
  @@index([orderNo])
}

model FoodOrderItem {
  id        Int        @id @default(autoincrement())
  orderId   Int
  order     FoodOrder  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dishId    Int
  dish      FoodDish   @relation(fields: [dishId], references: [id])
  quantity  Int        @default(1)
  price     Decimal    @db.Decimal(10, 2)
  createdAt DateTime   @default(now())

  @@index([orderId])
  @@index([dishId])
}

model FoodCart {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  dishId    Int
  dish      FoodDish  @relation(fields: [dishId], references: [id])
  quantity  Int       @default(1)
  tenantId  Int
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, dishId])
  @@index([tenantId])
}

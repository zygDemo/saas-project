{
  "name": "@saas/admin-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "dotenv -e env/.env.development -- cross-env NODE_ENV=development nest start --watch",
    "start:sit": "dotenv -e env/.env.sit -- cross-env NODE_ENV=sit nest start --watch",
    "start:prod": "cross-env NODE_ENV=production node dist/main.js",
    "start:prod:local": "dotenv -e env/.env.production -- cross-env NODE_ENV=production nest start --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest --config jest.config.ts --passWithNoTests",
    "test:watch": "jest --config jest.config.ts --watch --passWithNoTests",
    "test:cov": "jest --config jest.config.ts --coverage --passWithNoTests",
    "prisma:generate": "dotenv -e env/.env.development -- prisma generate",
    "prisma:migrate": "dotenv -e env/.env.development -- prisma migrate dev",
    "prisma:migrate:sit": "dotenv -e env/.env.sit -- prisma migrate deploy",
    "prisma:migrate:prod": "dotenv -e env/.env.production -- prisma migrate deploy",
    "prisma:seed": "dotenv -e env/.env.development -- tsx prisma/seed.ts",
    "prisma:seed:sit": "dotenv -e env/.env.sit -- tsx prisma/seed.ts",
    "prisma:seed:prod": "dotenv -e env/.env.production -- tsx prisma/seed.ts",
    "prisma:seed:reading:local": "dotenv -e env/.env.development -- tsx prisma/seed-reading.ts",
    "prisma:seed:reading:prod": "dotenv -e env/.env.production -- tsx prisma/seed-reading.ts",
    "db:sync-roles": "dotenv -e env/.env.development -- tsx prisma/migrate-roles-menus.ts",
    "db:sync-roles:sit": "dotenv -e env/.env.sit -- tsx prisma/migrate-roles-menus.ts",
    "db:sync-roles:prod": "dotenv -e env/.env.production -- tsx prisma/migrate-roles-menus.ts",
    "db:studio": "dotenv -e env/.env.development -- prisma studio"
  },
  "dependencies": {
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.2.1",
    "@saas/shared": "workspace:*",
    "axios": "^1.18.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.34.5",
    "cheerio": "^1.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "helmet": "^8.3.0",
    "iconv-lite": "^0.7.2",
    "ioredis": "^5.4.2",
    "nodemailer": "^9.0.3",
    "p-limit": "3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "playwright": "^1.61.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@swc/cli": "0.5.0",
    "@swc/core": "^1.15.43",
    "@types/bcryptjs": "^2.4.6",
    "@types/cheerio": "^1.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^8.0.1",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^7.4.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "jest": "^29.7.0",
    "prisma": "^6.2.1",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.20.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}

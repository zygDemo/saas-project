NODE_ENV=development
PORT=3001
API_PREFIX=/saas/api
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:5174

DATABASE_URL=postgresql://postgres:123456@127.0.0.1:5432/saas?schema=public
REDIS_HOST=localhost
REDIS_PORT=16379
REDIS_PASSWORD=

OCR_URL=https://www.yugui.store/saas/ocr
OCR_API_KEY=change-me-ocr-api-key
OCR_TIMEOUT_MS=60000

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# 邮件配置 (开发: 163邮箱 / 生产: 阿里云DirectMail)
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@163.com
SMTP_PASS=163授权码或DirectMail密码
MAIL_FROM=your-email@163.com

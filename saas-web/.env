# 【通用】环境变量

#  版本号
VITE_VERSION = 3.0.2

# 端口号
VITE_PORT = 3006

# 应用部署基础路径
VITE_BASE_URL = /saas/

# 权限模式【 frontend 前端模式 / backend 后端模式 】
VITE_ACCESS_MODE = backend

# 跨域请求时是否携带 Cookie（开启前需确保后端支持）
VITE_WITH_CREDENTIALS=false
VITE_TENANT_ID = 1

# 是否打开路由信息
VITE_OPEN_ROUTE_INFO = false

# 锁屏加密密钥
VITE_LOCK_ENCRYPT_KEY = s3cur3k3y4adpro
VITE_API_PROXY_URL = http://localhost:3001

# 前端监控埋点（错误/性能/行为上报），后端未实现 collect 接口，暂时关闭
VITE_MONITOR_ENABLED = false

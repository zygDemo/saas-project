<template>
  <ElDialog
    :model-value="modelValue"
    :title="formMode === 'create' ? `新增${displayTitle}` : `编辑${displayTitle}`"
    :width="dialogWidth"
    @update:model-value="$emit('update:modelValue', $event)"
  >
    <ElForm label-width="130px" class="business-form">
      <template v-for="(field, index) in formFields" :key="field.prop">
        <div v-if="shouldShowFieldGroup(field, index)" class="business-form__section">{{
          field.group
        }}</div>
        <ElFormItem :label="field.label" :required="field.required">
          <ElInputNumber
            v-if="field.type === 'number'"
            :model-value="formModel[field.prop] as number"
            :min="0"
            :precision="field.precision"
            controls-position="right"
            style="width: 100%"
            @update:model-value="updateField(field.prop, $event)"
          >
            <template v-if="field.unit" #suffix>{{ field.unit }}</template>
          </ElInputNumber>
          <ElSelect
            v-else-if="field.type === 'select'"
            :model-value="formModel[field.prop]"
            clearable
            filterable
            :placeholder="field.placeholder || `请选择${field.label}`"
            :loading="Boolean(selectLoading[field.prop])"
            style="width: 100%"
            @update:model-value="updateField(field.prop, $event)"
            @change="(value) => $emit('field-change', field, value)"
          >
            <ElOption
              v-for="option in fieldOptions(field)"
              :key="String(option.value)"
              :label="option.label"
              :value="option.value"
            />
          </ElSelect>
          <ElSwitch
            v-else-if="field.type === 'switch'"
            :model-value="formModel[field.prop] as boolean"
            @update:model-value="updateField(field.prop, $event)"
          />
          <ElDatePicker
            v-else-if="field.type === 'date'"
            :model-value="formModel[field.prop]"
            type="datetime"
            value-format="YYYY-MM-DDTHH:mm:ss.SSSZ"
            :placeholder="field.placeholder || `请选择${field.label}`"
            style="width: 100%"
            @update:model-value="updateField(field.prop, $event)"
          />
          <div v-else-if="field.type === 'fileChecklist'" class="file-checklist-editor">
            <ElButton type="primary" plain size="small" @click="addChecklistItem(field.prop)">
              <ElIcon><Plus /></ElIcon> 添加文件项
            </ElButton>
            <ElTable
              v-if="(formModel[field.prop] as FileChecklistItem[] | undefined)?.length"
              :data="(formModel[field.prop] as FileChecklistItem[]) || []"
              border
              size="small"
              style="margin-top: 8px"
            >
              <ElTableColumn label="文件名称" min-width="140">
                <template #default="{ row, $index }">
                  <ElInput
                    :model-value="row.name"
                    size="small"
                    placeholder="如：身份证人像面"
                    @update:model-value="updateChecklistItem(field.prop, $index, 'name', $event)"
                  />
                </template>
              </ElTableColumn>
              <ElTableColumn label="文件编码" width="140">
                <template #default="{ row, $index }">
                  <ElInput
                    :model-value="row.code"
                    size="small"
                    placeholder="如：ID_CARD_FRONT"
                    @update:model-value="updateChecklistItem(field.prop, $index, 'code', $event)"
                  />
                </template>
              </ElTableColumn>
              <ElTableColumn label="允许类型" min-width="160">
                <template #default="{ row, $index }">
                  <ElSelect
                    :model-value="row.fileTypes"
                    size="small"
                    multiple
                    filterable
                    allow-create
                    placeholder="如：jpg, pdf"
                    style="width: 100%"
                    @update:model-value="
                      updateChecklistItem(field.prop, $index, 'fileTypes', $event as string[])
                    "
                  >
                    <ElOption v-for="t in fileTypePresets" :key="t" :label="t" :value="t" />
                  </ElSelect>
                </template>
              </ElTableColumn>
              <ElTableColumn label="最大张数" width="100">
                <template #default="{ row, $index }">
                  <ElInputNumber
                    :model-value="row.maxCount"
                    size="small"
                    :min="1"
                    :max="20"
                    controls-position="right"
                    style="width: 100%"
                    @update:model-value="
                      updateChecklistItem(field.prop, $index, 'maxCount', $event)
                    "
                  />
                </template>
              </ElTableColumn>
              <ElTableColumn label="必传" width="70" align="center">
                <template #default="{ row, $index }">
                  <ElSwitch
                    :model-value="row.required"
                    size="small"
                    @update:model-value="
                      updateChecklistItem(field.prop, $index, 'required', $event)
                    "
                  />
                </template>
              </ElTableColumn>
              <ElTableColumn label="备注" min-width="120">
                <template #default="{ row, $index }">
                  <ElInput
                    :model-value="row.remark"
                    size="small"
                    placeholder="选填"
                    @update:model-value="updateChecklistItem(field.prop, $index, 'remark', $event)"
                  />
                </template>
              </ElTableColumn>
              <ElTableColumn label="操作" width="60" align="center">
                <template #default="{ $index }">
                  <ElButton
                    type="danger"
                    text
                    size="small"
                    @click="removeChecklistItem(field.prop, $index)"
                    >删</ElButton
                  >
                </template>
              </ElTableColumn>
            </ElTable>
            <div v-else class="file-checklist-empty">暂无文件项，点击上方按钮添加</div>
          </div>
          <ElInput
            v-else
            :model-value="formModel[field.prop] as string"
            clearable
            :autosize="
              field.type === 'json' || field.type === 'textarea'
                ? { minRows: 3, maxRows: 8 }
                : undefined
            "
            :placeholder="field.placeholder || `请输入${field.label}`"
            :type="field.type === 'textarea' || field.type === 'json' ? 'textarea' : 'text'"
            @update:model-value="updateField(field.prop, $event)"
          />
        </ElFormItem>
      </template>
    </ElForm>
    <template #footer>
      <ElButton @click="$emit('update:modelValue', false)">取消</ElButton>
      <ElButton type="primary" :loading="submitting" @click="$emit('submit')">保存</ElButton>
    </template>
  </ElDialog>
</template>

<script setup lang="ts">
  import { computed, type PropType } from 'vue'
  import { Plus } from '@element-plus/icons-vue'
  import type { FieldConfig, OptionConfig, FileChecklistItem } from './types'

  const props = defineProps({
    modelValue: {
      type: Boolean,
      required: true
    },
    formMode: {
      type: String as PropType<'create' | 'edit'>,
      required: true
    },
    displayTitle: {
      type: String,
      required: true
    },
    formFields: {
      type: Array as PropType<FieldConfig[]>,
      default: () => []
    },
    formModel: {
      type: Object as PropType<Record<string, unknown>>,
      required: true
    },
    selectLoading: {
      type: Object as PropType<Record<string, boolean>>,
      default: () => ({})
    },
    submitting: {
      type: Boolean,
      default: false
    },
    shouldShowFieldGroup: {
      type: Function as PropType<(field: FieldConfig, index: number) => boolean>,
      required: true
    },
    fieldOptions: {
      type: Function as PropType<(field: FieldConfig) => OptionConfig[]>,
      required: true
    }
  })

  const dialogWidth = computed(() => (props.displayTitle.includes('产品') ? '900px' : '600px'))

  const emit = defineEmits<{
    'update:modelValue': [value: boolean]
    'update:formModel': [value: Record<string, unknown>]
    'field-change': [field: FieldConfig, value: unknown]
    submit: []
  }>()

  function updateField(prop: string, value: unknown) {
    emit('update:formModel', {
      ...props.formModel,
      [prop]: value
    })
  }

  const fileTypePresets = ['jpg', 'jpeg', 'png', 'bmp', 'pdf', 'doc', 'docx', 'mp4', 'mov']

  function ensureChecklist(prop: string): FileChecklistItem[] {
    const existing = props.formModel[prop] as FileChecklistItem[] | undefined
    if (existing && Array.isArray(existing)) return existing
    return []
  }

  function addChecklistItem(prop: string) {
    const list = ensureChecklist(prop)
    const newItem: FileChecklistItem = {
      code: '',
      name: '',
      fileTypes: ['jpg', 'png', 'pdf'],
      maxCount: 1,
      required: false
    }
    updateField(prop, [...list, newItem])
  }

  function updateChecklistItem(
    prop: string,
    index: number,
    key: keyof FileChecklistItem,
    value: unknown
  ) {
    const list = ensureChecklist(prop)
    if (!list[index]) return
    list[index] = { ...list[index], [key]: value }
    updateField(prop, [...list])
  }

  function removeChecklistItem(prop: string, index: number) {
    const list = ensureChecklist(prop)
    list.splice(index, 1)
    updateField(prop, [...list])
  }
</script>

<style scoped>
  .business-form {
    max-height: 62vh;
    padding-right: 10px;
    overflow: auto;
  }

  .business-form__section {
    padding: 12px 0 10px;
    margin-bottom: 16px;
    font-size: 13px;
    font-weight: 600;
    color: var(--el-text-color-primary);
    border-bottom: 1px solid var(--el-border-color-lighter);
  }

  .file-checklist-editor {
    width: 100%;
  }

  .file-checklist-empty {
    padding: 16px;
    text-align: center;
    color: var(--el-text-color-secondary);
    font-size: 13px;
    border: 1px dashed var(--el-border-color);
    border-radius: 4px;
    margin-top: 8px;
  }
</style>
# 开发环境配置

# 环境标识
VITE_APP_ENV=development

# API 请求基础路径
VITE_API_URL=http://localhost:3001/saas/api

# API 基础地址
VITE_API_BASE_URL=http://localhost:3001/saas/api

# 图片基础地址
VITE_IMAGE_BASE_URL=http://localhost:3001/saas/api

# 应用名称
VITE_APP_NAME=予艺助手(开发版)

# 默认租户 ID
VITE_TENANT_ID=1

# 是否开启调试
VITE_DEBUG=true

# 上传文件大小限制 (MB)
VITE_UPLOAD_MAX_SIZE=10

# 请求超时时间 (ms)
VITE_REQUEST_TIMEOUT=30000
